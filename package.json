{
  "name": "receiptflow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run generate:route-meta && npm run sitemap",
    "build": "tsc -b && vite build && npm run prerender",
    "prerender": "node scripts/prerender-meta.mjs",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings 0",
    "validate:jsonld": "vite-node scripts/validate-jsonld.ts",
    "preview": "vite preview",
    "bootstrap:admin": "node scripts/bootstrap-super-admin.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "sitemap:images": "node scripts/generate-image-sitemap.mjs",
    "generate:route-meta": "node scripts/generate-route-meta.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.2",
    "@tanstack/react-query": "^5.101.2",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.24.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/exceljs": "^0.5.3",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.1"
  }
}
