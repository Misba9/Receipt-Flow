# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Public app URL (no trailing slash) — used for SEO/canonical links.
# Auth email redirects use window.location.origin at runtime (not this value),
# so the same build works on localhost and Vercel.
# Production: https://receipt-flow-azure.vercel.app
VITE_APP_URL=https://receipt-flow-azure.vercel.app
VITE_APP_NAME=ReceiptFlow

# Email mode: development | production
VITE_EMAIL_MODE=development

# -----------------------------------------------------------------------------
# Never put these in VITE_* or the browser bundle:
#   SUPABASE_SERVICE_ROLE_KEY
#   RESEND_API_KEY
#
# One global Resend account for all tenants. From address is platform-wide
# (RESEND_FROM_EMAIL). Reply-To uses the company's business email when set.
#
#   supabase secrets set RESEND_API_KEY=re_xxxxxxxxx
#   supabase secrets set RESEND_FROM_EMAIL="ReceiptFlow <billing@yourdomain.com>"
#   supabase secrets set APP_URL=https://receipt-flow-azure.vercel.app
# -----------------------------------------------------------------------------

# Multi-tenant + Super Admin
# Apply all files in supabase/migrations/ (see supabase/README.md).
# Bootstrap a super admin:
#   update public.profiles set is_super_admin = true where id = '<auth-user-uuid>';
#
# Onboarding: Confirm email should be OFF so signup returns a session and
# users can finish onboarding without blocking. Soft verification uses
# profiles.email_verified_at + a magic-link email (Settings / dashboard banner).
# Redirect URL allow-list still needs:
#   http://localhost:5173/auth/callback
#   https://your-production-domain/auth/callback
#   (include ?next=reset-password and ?next=email-verified variants if required)

# -----------------------------------------------------------------------------
# Platform super admin (never prefix with VITE_ — browser must not see these)
# Sign in at /login, then open /admin
#
#   ADMIN_EMAIL=admin@yourdomain.com
#   ADMIN_PASSWORD=choose-a-strong-password
#   ADMIN_FULL_NAME=Platform Admin
#   SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
#
# Then: npm run bootstrap:admin
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-strong-password
ADMIN_FULL_NAME=Platform Admin
# SUPABASE_SERVICE_ROLE_KEY=

