# =============================================================================
# ReceiptFlow — client (Vite) environment
# Copy to .env for local development. Set the same keys in Vercel → Settings → Env.
# =============================================================================

# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Public app URL (no trailing slash)
# Local:  http://localhost:5173
# Prod:   https://your-domain.com
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=ReceiptFlow

# -----------------------------------------------------------------------------
# Never put these in VITE_* or the browser bundle:
#   SUPABASE_SERVICE_ROLE_KEY
#   RESEND_API_KEY
# Set Resend secrets on the Edge Function instead:
#   supabase secrets set RESEND_API_KEY=re_xxxxxxxxx
#   supabase secrets set RESEND_FROM_EMAIL="ReceiptFlow <billing@yourdomain.com>"
#   supabase secrets set APP_URL=https://your-domain.com
# -----------------------------------------------------------------------------

# Multi-tenant + Super Admin
# Apply all files in supabase/migrations/ (see supabase/README.md).
# Bootstrap a super admin (SQL editor as postgres / service role):
#   update public.profiles set is_super_admin = true where id = '<auth-user-uuid>';
