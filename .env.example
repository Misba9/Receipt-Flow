# Copy to `.env` and fill in real values. Never commit secrets.

# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# App
VITE_APP_NAME=ReceiptFlow
VITE_APP_URL=https://receiptflow.velonerp.com
VITE_APP_ENV=development
VITE_EMAIL_MODE=development

# Search Console verification (optional — replace placeholders in index.html)
# Google Search Console → Settings → Ownership verification → HTML tag
VITE_GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools → Authentication → Meta tag
VITE_BING_SITE_VERIFICATION=
