# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Public app URL (no trailing slash)
# Local:  http://localhost:5173
# Prod:   https://your-domain.com
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=ReceiptFlow

# Email mode (client-visible — only VITE_* is read by the browser)
# development → EmailService simulates send (no Resend / Edge Function)
# production  → EmailService invokes send-invoice-email Edge Function
VITE_EMAIL_MODE=development


# -----------------------------------------------------------------------------
# Never put these in VITE_* or the browser bundle:
#   SUPABASE_SERVICE_ROLE_KEY
#   RESEND_API_KEY
# Set Resend secrets on the Edge Function instead:
#   supabase secrets set RESEND_API_KEY=re_xxxxxxxxx
#   supabase secrets set RESEND_FROM_EMAIL="ReceiptFlow <noreply@velonerp.com>"
#   supabase secrets set RESEND_VERIFIED_DOMAIN=velonerp.com
#   supabase secrets set APP_URL=https://your-domain.com
# -----------------------------------------------------------------------------

# Multi-tenant + Super Admin
# Apply all files in supabase/migrations/ (see supabase/README.md).
# Bootstrap a super admin (SQL editor as postgres / service role):
#   update public.profiles set is_super_admin = true where id = '<auth-user-uuid>';
